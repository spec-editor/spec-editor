# .env — Spec Editor API keys and settings
# Copy .env.example to .env and fill in your keys

# === LLM Providers (required) ===
DEEPSEEK_API_KEY=sk-...
# OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...
# OLLAMA_HOST=http://localhost:11434

# === Timeouts ===
# Maximum dialogue duration (minutes)
SPEC_EDITOR__MAX_TIME_MINUTES=480
# Single HTTP request timeout to LLM (seconds)
SPEC_EDITOR__LLM_REQUEST_TIMEOUT=90
# Total timeout including retries (seconds)
SPEC_EDITOR__LLM_TOTAL_TIMEOUT=90

# === Agent Limits ===
# Maximum LLM calls per agent run
SPEC_EDITOR__MAX_LLM_CALLS=30
# Token budget before automatic context compaction
SPEC_EDITOR__TOKEN_BUDGET=50000
# Maximum concurrent agents
SPEC_EDITOR__MAX_AGENTS=8

# === Logging ===
# Level: DEBUG, INFO, WARNING, ERROR
# SPEC_EDITOR__LOG_LEVEL=INFO
# Path to log file (optional)
# SPEC_EDITOR__LOG_FILE=./spec-editor.log
# JSON log format
# SPEC_EDITOR__LOG_JSON=false

# === Docker ===
# Path to spec-editor projects (mounted as /projects in container)
# SPEC_PROJECTS_DIR=/Users/you/spec-projects
