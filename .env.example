# .env — API-ключи и настройки Spec Editor
# Скопируйте .env.example в .env и заполните

# === LLM-провайдеры (обязательно) ===
DEEPSEEK_API_KEY=sk-...
# OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...
# OLLAMA_HOST=http://localhost:11434

# === Таймауты ===
# Максимальная длительность диалога (минут)
SPEC_EDITOR__MAX_TIME_MINUTES=480
# Таймаут одного HTTP-запроса к LLM (секунд)
SPEC_EDITOR__LLM_REQUEST_TIMEOUT=90
# Общий таймаут с учётом повторных попыток (секунд)
SPEC_EDITOR__LLM_TOTAL_TIMEOUT=90

# === Лимиты агентов ===
# Максимум LLM-вызовов за один ход агента (run)
SPEC_EDITOR__MAX_LLM_CALLS=30
# Токен-бюджет до автоматического сжатия контекста
SPEC_EDITOR__TOKEN_BUDGET=50000
# Максимум одновременно работающих агентов
SPEC_EDITOR__MAX_AGENTS=8

# === Логирование ===
# Уровень: DEBUG, INFO, WARNING, ERROR
# SPEC_EDITOR__LOG_LEVEL=INFO
# Путь к файлу логов (если нужен)
# SPEC_EDITOR__LOG_FILE=./spec-editor.log
# JSON-формат логов
# SPEC_EDITOR__LOG_JSON=false
