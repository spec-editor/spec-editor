# ──────────────────────────────────────────────────────────────
# Python
# ──────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.egg-info/
dist/
build/
.eggs/

# ──────────────────────────────────────────────────────────────
# Virtual environment
# ──────────────────────────────────────────────────────────────
.venv/
venv/
.python-version

# ──────────────────────────────────────────────────────────────
# Environment & Secrets — NEVER commit real credentials
# ──────────────────────────────────────────────────────────────
.env
hooks.yaml                     # Real Telegram API keys — use hooks.example.yaml
local.yaml                    # Real API keys, license keys — use local.example.yaml

# ──────────────────────────────────────────────────────────────
# IDE / Editor
# ──────────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*.code-workspace

# ──────────────────────────────────────────────────────────────
# OS
# ──────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db

# ──────────────────────────────────────────────────────────────
# Project — generated / runtime artifacts
# ──────────────────────────────────────────────────────────────
*.log
*.db
*.sqlite
*.sqlite3
dialogue.log
dialogue.jsonl
dialogue.json
dialogue.yaml

# spec-editor lock & run files
.spec-editor-*

# License validation cache (contains license keys)
license.cache
~/.spec-editor/

# OpenCode config (may have local paths)
opencode.json

# ──────────────────────────────────────────────────────────────
# Generated aspect folders
# (protected against accidental run without -p flag)
# ──────────────────────────────────────────────────────────────
user_interface/
user_scenarios/
modules/
data_entities/
non_functional/
aspects/
!data/examples/bookstore/aspects/
!data/examples/bookstore/aspects/**

# ──────────────────────────────────────────────────────────────
# Project-local overrides (templates are tracked instead)
# ──────────────────────────────────────────────────────────────
source/
methodology.yaml
!data/methodology.yaml
agents.yaml

# ──────────────────────────────────────────────────────────────
# Ingestion pipeline output
# ──────────────────────────────────────────────────────────────
ingestion/

# ──────────────────────────────────────────────────────────────
# Source raw documents
# ──────────────────────────────────────────────────────────────
source_raw/*
!source_raw/.gitkeep
sources_raw/

# ──────────────────────────────────────────────────────────────
# Agent execution logs
# ──────────────────────────────────────────────────────────────
logs/

# ──────────────────────────────────────────────────────────────
# Test / CI artifacts
# ──────────────────────────────────────────────────────────────
.pytest_cache/
.coverage
htmlcov/
test-results/

# ──────────────────────────────────────────────────────────────
# Internal docs (not for OSS publication)
# ──────────────────────────────────────────────────────────────
Development/
Product/
spec-editor-session.*
new_features.txt
deploy.yaml

# ──────────────────────────────────────────────────────────────
# Paid / Pro content — NOT in OSS repo
# ──────────────────────────────────────────────────────────────
paid-methodologies/
cloud-proxy/                              # Cloud token proxy backend (paid)
plugins/cycle/                            # Pro multi-agent codegen plugin (paid)
src/licensing/gumroad.py                  # GumRoad API integration (paid)

# ──────────────────────────────────────────────────────────────
# Session artifacts
# ──────────────────────────────────────────────────────────────
dialogue.jsonl

# ──────────────────────────────────────────────────────────────
